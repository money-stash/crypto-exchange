# Exchange MVP environment example
#
# Use this as a template:
# 1) copy to backend/.env for backend runtime
# 2) copy frontend vars (VITE_*) to frontend/.env
# 3) never commit real secrets/tokens

# ------------------------------------------------------------------------------
# Core app
# ------------------------------------------------------------------------------
NODE_ENV=development
PORT=8080
FRONTEND_URL=http://localhost:5173

# ------------------------------------------------------------------------------
# Database (required)
# ------------------------------------------------------------------------------
MYSQL_URI=mysql://root:root@localhost:3306/exchange_db

# Optional MySQL vars (useful for local/docker setup scripts)
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=exchange_db
MYSQL_USER=root
MYSQL_PASSWORD=root

# ------------------------------------------------------------------------------
# Security (required in production)
# ------------------------------------------------------------------------------
JWT_SECRET=change_me_to_a_long_random_string
AES_KEY_HEX=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
ENCRYPTION_KEY=change_me_encryption_key

# ------------------------------------------------------------------------------
# Telegram bot (required)
# ------------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=123456789:replace_with_real_token

# Optional Telegram channels/bots for alerts/logs
ORDER_LOG_BOT_TOKEN=
ORDER_LOG_CHAT_ID=
ORDER_LOG_METHOD_LABEL=SBP

OPERATOR_ALERT_BOT_TOKEN=
OPERATOR_ALERT_CHAT_ID=
OPERATOR_ALERT_METHOD_LABEL=SBP / Card

MANAGER_ALERT_BOT_TOKEN=
MANAGER_ALERT_CHAT_ID=

ACTIVATION_ALERT_BOT_TOKEN=
ACTIVATION_ALERT_CHAT_ID=

# ------------------------------------------------------------------------------
# OpenAI translation (optional)
# ------------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_TRANSLATION_MODEL=gpt-5.4-mini
OPENAI_TRANSLATION_TIMEOUT_MS=8000

# ------------------------------------------------------------------------------
# Rates / market APIs
# ------------------------------------------------------------------------------
BINANCE_API_BASE=https://api.binance.com
BYBIT_API_BASE=https://api.bybit.com
BYBIT_P2P_API_URL=https://api2.bybit.com/fiat/otc/item/online
KRAKEN_API_URL=https://api.kraken.com/0/public/Ticker
RATE_FETCH_TIMEOUT_MS=20000

# If you use proxy for rate requests:
RATE_PROXY_URL=
RAPIRA_PROXY_URL=

# Rapira USDT/RUB source settings
RAPIRA_API_URL=https://api.rapira.net/open/market/rates
RAPIRA_REQUEST_TIMEOUT_MS=2500
RAPIRA_FAILURE_COOLDOWN_MS=30000
RAPIRA_CACHE_TTL_MINUTES=15
RAPIRA_ALLOW_STALE_CACHE=true

# ------------------------------------------------------------------------------
# Exchange behavior
# ------------------------------------------------------------------------------
CRON_RATES=*/5 * * * *
SLA_MINUTES=30
USDT_FALLBACK_RATE_RUB=100
USDT_INTENT_TTL_MINUTES=20

# ------------------------------------------------------------------------------
# TRONSCAN / TRC20 USDT verification (optional)
# ------------------------------------------------------------------------------
TRONSCAN_API_BASE=https://apilist.tronscanapi.com
TRC20_USDT_CONTRACT=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t

# ------------------------------------------------------------------------------
# Frontend (Vite)
# ------------------------------------------------------------------------------
VITE_API_URL=http://localhost:8080

# ------------------------------------------------------------------------------
# Migrations (optional one-off override)
# ------------------------------------------------------------------------------
MIGRATION_FILE=
